{
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend/main.py",
            "routePrefix": "/api",
            "framework": "fastapi",
            "maxDuration": 120,
            "memory": 1024,
            "buildCommand": "rm -rf backend/skills backend/core_agents backend/memory && cp -R skills core_agents memory backend/"
        }
    }
}
