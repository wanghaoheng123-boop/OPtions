{
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend/main.py",
            "routePrefix": "/api",
            "framework": "fastapi",
            "maxDuration": 120,
            "memory": 1024,
            "installCommand": "python -m pip install --upgrade pip && python -m pip install -r backend/requirements.txt"
        }
    }
}
